    {
      "name": "search_restaurants",
      "description": "Search for restaurants by location and cuisine type"
    },
    {
      "name": "get_menu",
      "description": "Get menu items, prices, and details for a restaurant"
    },
    {
      "name": "place_order",
      "description": "Place a food delivery or restaurant reservation order"
    },
    {
      "name": "track_order",
      "description": "Track the status of a current order"
    },
    {
      "name": "search_groceries",
      "description": "Search for grocery items by store and category"
    },
    {
      "name": "add_to_cart",
      "description": "Add items to shopping cart"
    },
    {
      "name": "checkout",
      "description": "Complete purchase and arrange delivery"
    },
    {
      "name": "search_pet_services",
      "description": "Search for dog walkers, pet sitters, and pet services"
    },
    {
      "name": "book_pet_service",
      "description": "Book a dog walker or pet sitting appointment"
    },
    {
      "name": "search_rides",
      "description": "Search for available rides and fare estimates"
    },
    {
      "name": "request_ride",
      "description": "Request a ride (UberX, Uber Eats delivery, etc.)"
    },
    {
      "name": "search_hotels",
      "description": "Search for hotels and check availability"
    },
    {
      "name": "book_hotel",
      "description": "Book a hotel reservation"
    },
    {
      "name": "search_flights",
      "description": "Search for flights by origin, destination, and dates"
    },
    {
      "name": "book_flight",
      "description": "Book a flight"
