    {
      "name": "check_account_balance",
      "description": "Check account balance for financial institutions"
    },
    {
      "name": "transfer_funds",
      "description": "Transfer funds between accounts"
    },
    {
      "name": "pay_bill",
      "description": "Pay a bill or insurance premium"
